{
  "headers": [
    {
      "source": "/shortcuts/(.*)\\.shortcut",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!shortcuts/).*)", "destination": "/index.html" }
  ]
}
